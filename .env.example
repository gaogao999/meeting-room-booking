# ===== サーバ設定 =====
PORT=3000
NODE_ENV=development

# ===== データベース =====
# SQLite ファイルの保存先
DB_PATH=./data/booking.db

# ===== 認証 =====
# 本番では既存の /checklogin を利用する。
# 開発中は AUTH_MODE=mock でモック認証を有効化する。
AUTH_MODE=mock
# 本番連携時の /checklogin エンドポイント
CHECKLOGIN_URL=https://example.com/checklogin
# モック認証で利用する既定ユーザー（開発用）
MOCK_USER_NAME=山田 太郎
MOCK_USER_DEPARTMENT=総務部

# ===== 予約可能期間（日数）=====
# HR 系部門はより長期の予約が可能
BOOKING_WINDOW_DEFAULT_DAYS=90
BOOKING_WINDOW_HR_DAYS=180
# HR とみなす部門名（カンマ区切り、部分一致）
HR_DEPARTMENTS=人事部,HR,人事,採用,人材開発

# ===== 予約の刻み（分）=====
SLOT_MINUTES=10

# ===== ERP 連携（mssql / SELECT のみ / 後で追加）=====
# 有効化する場合は ERP_ENABLED=true
ERP_ENABLED=false
ERP_DB_SERVER=
ERP_DB_PORT=1433
ERP_DB_DATABASE=
ERP_DB_USER=
ERP_DB_PASSWORD=
ERP_DB_ENCRYPT=true
